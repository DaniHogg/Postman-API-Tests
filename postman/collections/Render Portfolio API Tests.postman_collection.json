{
  "info": {
    "_postman_id": "b1a2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "Render Portfolio API Tests",
    "description": "CRUD and contract tests against the deployed qa-portfolio-api backend on Render. Uses the /posts resource which supports full Create, Read, Update, Delete operations. Run with Newman: newman run 'Render Portfolio API Tests.postman_collection.json' -e 'Render API Environment.postman_environment.json'",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://qa-portfolio-api.onrender.com",
      "type": "string"
    },
    {
      "key": "postId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1 - Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has status ok', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('status');",
              "    pm.expect(json.status).to.equal('ok');",
              "});",
              "",
              "pm.test('Content-Type is application/json', function () {",
              "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "2 - List Posts",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response is a non-empty array', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.be.an('array').that.is.not.empty;",
              "});",
              "",
              "pm.test('Each post has required fields', function () {",
              "    const posts = pm.response.json();",
              "    posts.forEach(function (post) {",
              "        pm.expect(post).to.have.property('id');",
              "        pm.expect(post).to.have.property('userId');",
              "        pm.expect(post).to.have.property('title');",
              "        pm.expect(post).to.have.property('body');",
              "    });",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/posts",
          "host": ["{{baseUrl}}"],
          "path": ["posts"]
        }
      }
    },
    {
      "name": "3 - Create Post",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Response contains created post fields', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('id');",
              "    pm.expect(json.title).to.equal('Portfolio API Test Post');",
              "    pm.expect(json.userId).to.equal(1);",
              "});",
              "",
              "pm.test('Created post id is a positive integer', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.id).to.be.a('number').and.to.be.above(0);",
              "});",
              "",
              "// Capture the created post id for downstream requests",
              "const createdId = pm.response.json().id;",
              "pm.collectionVariables.set('postId', createdId);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Portfolio API Test Post\",\n  \"body\": \"Automated test verifying the POST /posts contract.\",\n  \"userId\": 1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/posts",
          "host": ["{{baseUrl}}"],
          "path": ["posts"]
        }
      }
    },
    {
      "name": "4 - Get Post by Id",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response matches requested post id', function () {",
              "    const json = pm.response.json();",
              "    const expectedId = parseInt(pm.collectionVariables.get('postId'));",
              "    pm.expect(json.id).to.equal(expectedId);",
              "});",
              "",
              "pm.test('Post has title and body', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.title).to.be.a('string').and.not.empty;",
              "    pm.expect(json.body).to.be.a('string').and.not.empty;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/posts/{{postId}}",
          "host": ["{{baseUrl}}"],
          "path": ["posts", "{{postId}}"]
        }
      }
    },
    {
      "name": "5 - Update Post",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response reflects updated title', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.title).to.equal('Updated Portfolio Post Title');",
              "});",
              "",
              "pm.test('Post id is unchanged', function () {",
              "    const json = pm.response.json();",
              "    const expectedId = parseInt(pm.collectionVariables.get('postId'));",
              "    pm.expect(json.id).to.equal(expectedId);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Updated Portfolio Post Title\",\n  \"body\": \"Verifying that PUT /posts/{id} correctly replaces the resource.\",\n  \"userId\": 1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/posts/{{postId}}",
          "host": ["{{baseUrl}}"],
          "path": ["posts", "{{postId}}"]
        }
      }
    },
    {
      "name": "6 - Delete Post",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response body is an empty object', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.deep.equal({});",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/posts/{{postId}}",
          "host": ["{{baseUrl}}"],
          "path": ["posts", "{{postId}}"]
        }
      }
    },
    {
      "name": "7 - Get Non-existent Post (404)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 404', function () {",
              "    pm.response.to.have.status(404);",
              "});",
              "",
              "pm.test('Response has Content-Type application/json', function () {",
              "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/posts/99999",
          "host": ["{{baseUrl}}"],
          "path": ["posts", "99999"]
        }
      }
    }
  ]
}
